# Copy this file to `.env` and adjust the values for your environment.

# Secret required in the `X-API-Key` header to create short URLs.
# Change this to a long random string before deploying anywhere public.
API_KEY=dev-secret-key

# Path to the SQLite database file (created on first run).
DATABASE_PATH=urls.db

# Public base URL used to build the full short link, e.g. http://host/abc123.
# No trailing slash.
BASE_URL=http://localhost:8000

# Number of characters in a generated short code.
SHORT_CODE_LENGTH=7
